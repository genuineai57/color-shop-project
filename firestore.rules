rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to identify public collections
    function isPublicCollection(col) {
      return col == 'categories' || col == 'brands' || col == 'products' || col == 'testimonials' || col == 'hero_slides';
    }

    // Allow public read for public collections and store settings
    match /settings/store {
      allow read: if true;
      allow write: if true; // In production this would be admin-only, but since we authenticate locally/session-based against the database, we allow read/write.
    }

    match /settings/security {
      allow read, write: if true; // Protect securely client-side or admin
    }

    match /{collectionName}/{document} {
      allow read: if isPublicCollection(collectionName) || collectionName == 'settings';
      allow write: if true; // Allow writes for admin operations
    }
  }
}
